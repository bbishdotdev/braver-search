    <string>NSApplication</string>
    <key>NSHumanReadableCopyright</key>
	<string>Copyright © 2026 Brenden Bishop. All rights reserved.</string>
    <key>ITSAppUsesNonExemptEncryption</key>
	<false/>
    <key>POSTHOG_API_KEY</key>
    <string>$(POSTHOG_API_KEY)</string>
    <key>POSTHOG_HOST</key>
    <string>$(POSTHOG_HOST)</string>
    <key>PAID_LAUNCH_ISO8601</key>
    <string>$(PAID_LAUNCH_ISO8601)</string>
